generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// Usuários do sistema (admin e clientes)
model User {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  password     String
  phone        String?
  role         Role     @default(CLIENT)
  active       Boolean  @default(true)
  street       String?  @map("street")
  number       String?  @map("number")
  complement   String?  @map("complement")
  neighborhood String?  @map("neighborhood")
  city         String?  @map("city")
  state        String?  @map("state")
  zipCode      String?  @map("zip_code")
  reference    String?  @map("reference") @db.VarChar(200)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  instances  Instance[]
  orders     Order[]
  categories Category[]
  products   Product[]
  combos            Combo[]
  account           Account?
  agentInstructions AgentInstruction[]
  customers         Customer[]
  agendaSlots       AgendaSlot[]
  materials             Material[]
  shoppingLists         ShoppingList[]
  recipes               Recipe[]
  notificationsReceived Notification[] @relation("NotificationReceiver")
  notificationsSent     Notification[] @relation("NotificationSender")
  deliveryZones         DeliveryZone[]

  @@map("users")
}

// Clientes compradores (gerenciados pelo dono da fábrica)
model Customer {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  name         String
  password     String?
  phone        String?
  email        String?
  notes        String?  @db.Text
  street       String?
  number       String?
  complement   String?
  neighborhood String?
  city         String?
  state        String?  @db.VarChar(2)
  zipCode      String?  @map("zip_code")
  reference    String?  @db.VarChar(200)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@map("customers")
}

enum Role {
  SUPERADMIN
  ADMIN
  CLIENT
}

// Planos de assinatura
model Plan {
  id          Int      @id @default(autoincrement())
  title       String
  description String?  @db.Text
  price       Decimal  @db.Decimal(10, 2)
  features    String?  @db.Text  // JSON array de tópicos ex: ["Agente IA 24h", "Cardápio digital"]
  trialDays   Int      @default(15) @map("trial_days")
  popular     Boolean  @default(false)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  accounts Account[]

  @@map("plans")
}

// Conta do usuário (dados empresariais + plano)
model Account {
  id            Int           @id @default(autoincrement())
  userId        Int           @unique @map("user_id")
  planId        Int?          @map("plan_id")
  companyName   String?       @map("company_name")
  legalName     String?       @map("legal_name")
  document      String?       @db.VarChar(18) // CPF (14) ou CNPJ (18) formatado
  documentType  DocumentType? @map("document_type")
  logoUrl       String?       @map("logo_url") @db.Text
  responsible   String?
  hourlyRate    Decimal?      @map("hourly_rate") @db.Decimal(10, 2)
  useReservation Boolean      @default(false) @map("use_reservation")
  reservationPercent Int?     @map("reservation_percent")
  status        AccountStatus @default(ACTIVE)
  trialEndsAt   DateTime?     @map("trial_ends_at")
  planStartedAt DateTime?     @map("plan_started_at")
  planExpiresAt DateTime?     @map("plan_expires_at")
  billingDay    Int?          @map("billing_day")  // dia do vencimento: 5, 10, 15 ou 25
  notes         String?       @db.Text
  slug          String?       @unique @db.VarChar(100)
  storeActive   Boolean       @default(false) @map("store_active")
  deliveryEnabled Boolean     @default(false) @map("delivery_enabled")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan     Plan?     @relation(fields: [planId], references: [id])
  payments Payment[]

  @@map("accounts")
}

// Taxas de entrega por cidade/bairro
model DeliveryZone {
  id            Int      @id @default(autoincrement())
  userId        Int      @map("user_id")
  name          String   @db.VarChar(150)  // cidade ou bairro
  fee           Decimal  @db.Decimal(10, 2)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("delivery_zones")
}

// Notificações enviadas pelo superadmin aos clientes
model Notification {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  sentBy      Int      @map("sent_by")
  type        String   // ex: deactivation-warning
  emailSent   Boolean  @default(false) @map("email_sent")
  whatsappSent Boolean @default(false) @map("whatsapp_sent")
  createdAt   DateTime @default(now()) @map("created_at")

  user   User @relation("NotificationReceiver", fields: [userId], references: [id], onDelete: Cascade)
  sender User @relation("NotificationSender", fields: [sentBy], references: [id], onDelete: Cascade)

  @@map("notifications")
}

enum DocumentType {
  CPF
  CNPJ
}

enum AccountStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  TRIAL
}

// Histórico de pagamentos
model Payment {
  id            Int           @id @default(autoincrement())
  code          String        @unique @db.VarChar(4)
  accountId     Int           @map("account_id")
  amount        Decimal       @db.Decimal(10, 2)
  method        PaymentMethod?
  status        PaymentStatus @default(PENDING)
  referenceMonth String?      @map("reference_month") @db.VarChar(7) // "2026-03"
  externalId    String?       @map("external_id")     // ID do gateway de pagamento
  proofUrl      String?       @map("proof_url") @db.Text  // comprovante PIX anexado pelo cliente
  dueDate       DateTime?     @map("due_date") @db.Date   // data de vencimento
  paidAt        DateTime?     @map("paid_at")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("payments")
}

enum PaymentMethod {
  PIX
  CREDIT_CARD
  BOLETO
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  CANCELLED
}

// Instâncias do WhatsApp (Evolution API)
model Instance {
  id             Int            @id @default(autoincrement())
  userId         Int            @map("user_id")
  instanceName   String         @unique @map("instance_name")
  instanceId     String?        @map("instance_id")
  status         InstanceStatus @default(DISCONNECTED)
  phone          String?
  profileName    String?        @map("profile_name")
  profilePicUrl  String?        @map("profile_pic_url") @db.Text
  webhookUrl     String?        @map("webhook_url") @db.Text
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  chatbot  Chatbot?
  messages Message[]

  @@map("instances")
}

enum InstanceStatus {
  CONNECTED
  DISCONNECTED
  CONNECTING
}

// Configuração do chatbot por instância
model Chatbot {
  id           Int      @id @default(autoincrement())
  instanceId   Int      @unique @map("instance_id")
  welcomeMsg   String?  @map("welcome_msg") @db.Text
  menuMsg      String?  @map("menu_msg") @db.Text
  closingMsg   String?  @map("closing_msg") @db.Text
  active       Boolean  @default(true)
  businessHoursStart String? @map("business_hours_start")
  businessHoursEnd   String? @map("business_hours_end")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  instance Instance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@map("chatbots")
}

// Categorias de produtos
model Category {
  id        Int       @id @default(autoincrement())
  userId    Int       @map("user_id")
  name      String
  active    Boolean   @default(true)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  user               User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  products           Product[]
  agendaCategorySlots AgendaCategorySlot[]

  @@map("categories")
}

// Produtos (bolos, doces, etc)
model Product {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  categoryId  Int      @map("category_id")
  name        String
  description String?  @db.Text
  price       Decimal  @db.Decimal(10, 2)
  minOrder    Int      @default(1) @map("min_order")
  maxOrder    Int      @default(500) @map("max_order")
  imageUrl                String?  @map("image_url") @db.Text
  allowInspirationImages  Boolean  @default(false) @map("allow_inspiration_images")
  inspirationInstruction  String?  @map("inspiration_instruction") @db.Text
  maxInspirationImages    Int      @default(3) @map("max_inspiration_images")
  recipeId                Int?     @map("recipe_id")
  active                  Boolean  @default(true)
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  category   Category    @relation(fields: [categoryId], references: [id])
  recipe     Recipe?     @relation(fields: [recipeId], references: [id])
  orderItems OrderItem[]
  comboItems ComboItem[]

  @@map("products")
}

// Combos (conjunto de produtos com desconto)
model Combo {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  name        String
  description String?  @db.Text
  discount    Decimal  @default(0) @db.Decimal(10, 2) // valor do desconto
  imageUrl    String?  @map("image_url") @db.Text
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items ComboItem[]

  @@map("combos")
}

// Itens do combo
model ComboItem {
  id        Int @id @default(autoincrement())
  comboId   Int @map("combo_id")
  productId Int @map("product_id")
  quantity  Int @default(1)
  sortOrder Int @default(0) @map("sort_order")

  combo   Combo   @relation(fields: [comboId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@unique([comboId, productId])
  @@map("combo_items")
}

// Pedidos
model Order {
  id              Int         @id @default(autoincrement())
  orderNumber     Int         @map("order_number")
  userId          Int         @map("user_id")
  customerId      Int?        @map("customer_id")
  customerName    String      @map("customer_name")
  customerPhone   String      @map("customer_phone")
  remoteJid       String?     @map("remote_jid")
  status          OrderStatus @default(PENDING)
  total           Decimal     @db.Decimal(10, 2)
  reservation     Decimal?    @db.Decimal(10, 2)
  deliveryFee     Decimal?    @map("delivery_fee") @db.Decimal(10, 2)
  deliveryType    String?     @map("delivery_type") @db.VarChar(20)
  deliveryAddress String?     @map("delivery_address") @db.Text
  paymentProof    String?     @map("payment_proof") @db.Text
  proofVerified   Boolean     @default(false) @map("proof_verified")
  paymentConfirmed Boolean    @default(false) @map("payment_confirmed")
  depositAmount   Decimal?    @map("deposit_amount") @db.Decimal(10, 2)
  depositDivergence Boolean   @default(false) @map("deposit_divergence")
  estimatedDeliveryDate String? @map("estimated_delivery_date") @db.VarChar(100)
  notes           String?     @db.Text
  internalNotes   String?     @map("internal_notes") @db.Text
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  stockDeducted Boolean  @default(false) @map("stock_deducted")

  user           User             @relation(fields: [userId], references: [id])
  customer       Customer?        @relation(fields: [customerId], references: [id])
  items          OrderItem[]
  stockMovements StockMovement[]

  @@unique([userId, orderNumber])
  @@map("orders")
}

enum OrderStatus {
  PENDING
  RESERVATION
  CONFIRMED
  PREPARING
  READY
  DELIVERED
  CANCELLED
}

// Itens do pedido
model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int     @map("order_id")
  productId Int     @map("product_id")
  quantity  Int
  price     Decimal @db.Decimal(10, 2)

  order       Order                @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product              @relation(fields: [productId], references: [id])
  attachments OrderItemAttachment[]

  @@map("order_items")
}

// Anexos de inspiração enviados pelo cliente no pedido
model OrderItemAttachment {
  id          Int      @id @default(autoincrement())
  orderItemId Int      @map("order_item_id")
  imageUrl    String   @map("image_url") @db.Text
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  orderItem OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@map("order_item_attachments")
}

// Instruções do agente de atendimento
model AgentInstruction {
  id        Int                      @id @default(autoincrement())
  userId    Int                      @map("user_id")
  category  AgentInstructionCategory
  title     String
  content   String                   @db.Text
  imageUrl  String?                  @map("image_url") @db.Text
  active    Boolean                  @default(true)
  sortOrder Int                      @default(0) @map("sort_order")
  createdAt DateTime                 @default(now()) @map("created_at")
  updatedAt DateTime                 @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("agent_instructions")
}

enum AgentInstructionCategory {
  GREETING
  COMPANY
  ORDERS
  PRODUCTS
  QUESTIONS
  CLOSING
}

// Agenda de capacidade diária do operador
model AgendaSlot {
  id            Int      @id @default(autoincrement())
  userId        Int      @map("user_id")
  date          DateTime @db.Date
  maxOrders     Int      @map("max_orders")
  currentOrders Int      @default(0) @map("current_orders")
  active        Boolean  @default(true)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  categorySlots  AgendaCategorySlot[]

  @@unique([userId, date])
  @@map("agenda_slots")
}

// Limite de unidades por categoria em cada dia da agenda
model AgendaCategorySlot {
  id            Int      @id @default(autoincrement())
  agendaSlotId  Int      @map("agenda_slot_id")
  categoryId    Int      @map("category_id")
  maxUnits      Int      @map("max_units")
  currentUnits  Int      @default(0) @map("current_units")

  agendaSlot AgendaSlot @relation(fields: [agendaSlotId], references: [id], onDelete: Cascade)
  category   Category   @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([agendaSlotId, categoryId])
  @@map("agenda_category_slots")
}

// Receitas de produção (custo)
model Recipe {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  name        String
  description String?  @db.Text
  prepTime    Int      @default(0) @map("prep_time") // tempo em minutos
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  items    RecipeItem[]
  products Product[]

  @@map("recipes")
}

// Itens da receita (materiais usados)
model RecipeItem {
  id         Int     @id @default(autoincrement())
  recipeId   Int     @map("recipe_id")
  materialId Int     @map("material_id")
  quantity   Decimal @default(1) @db.Decimal(10, 2)

  recipe   Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  material Material @relation(fields: [materialId], references: [id])

  @@unique([recipeId, materialId])
  @@map("recipe_items")
}

// Materiais para produção
model Material {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  name      String
  unit      String?  @db.VarChar(50)  // ex: "500g", "1kg", "1L"
  brand     String?
  category  String?  @db.VarChar(100) // ex: "Laticínios", "Farinhas"
  refCode   String?  @map("ref_code") @db.VarChar(50)
  basePrice Decimal  @default(0) @map("base_price") @db.Decimal(10, 2)
  stock     Decimal  @default(0) @db.Decimal(10, 2)
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  shoppingListItems ShoppingListItem[]
  recipeItems       RecipeItem[]
  stockMovements    StockMovement[]

  @@map("materials")
}

// Listas de compras
model ShoppingList {
  id        Int              @id @default(autoincrement())
  userId    Int              @map("user_id")
  name      String
  status    ShoppingListStatus @default(OPEN)
  discount      Decimal          @default(0) @db.Decimal(10, 2)
  stockInserted Boolean          @default(false) @map("stock_inserted")
  closedAt      DateTime?        @map("closed_at")
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  user  User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  items ShoppingListItem[]

  @@map("shopping_lists")
}

enum ShoppingListStatus {
  OPEN
  CLOSED
}

// Itens da lista de compras
model ShoppingListItem {
  id             Int      @id @default(autoincrement())
  shoppingListId Int      @map("shopping_list_id")
  materialId     Int      @map("material_id")
  quantity          Decimal  @default(1) @db.Decimal(10, 2)
  actualPrice       Decimal? @map("actual_price") @db.Decimal(10, 2)
  previousBasePrice Decimal? @map("previous_base_price") @db.Decimal(10, 2)
  checked           Boolean  @default(false)

  shoppingList ShoppingList @relation(fields: [shoppingListId], references: [id], onDelete: Cascade)
  material     Material     @relation(fields: [materialId], references: [id])

  @@unique([shoppingListId, materialId])
  @@map("shopping_list_items")
}

// Movimentações de estoque
model StockMovement {
  id          Int      @id @default(autoincrement())
  materialId  Int      @map("material_id")
  orderId     Int?     @map("order_id")
  quantity    Decimal  @db.Decimal(10, 2) // negativo = saída, positivo = entrada
  type        String   @db.VarChar(30) // ORDER_DELIVERY, ORDER_DELIVERY_REVERT, SHOPPING_LIST, MANUAL
  description String?  @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at")

  material Material @relation(fields: [materialId], references: [id], onDelete: Cascade)
  order    Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@map("stock_movements")
}

// Mensagens do WhatsApp (log)
model Message {
  id            Int      @id @default(autoincrement())
  instanceId    Int      @map("instance_id")
  remoteJid     String   @map("remote_jid")
  fromMe        Boolean  @default(false) @map("from_me")
  messageType   String   @map("message_type")
  content       String   @db.Text
  promptTokens  Int?     @map("prompt_tokens")
  completionTokens Int?  @map("completion_tokens")
  totalTokens   Int?     @map("total_tokens")
  createdAt     DateTime @default(now()) @map("created_at")

  instance Instance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@map("messages")
}

// Visitas ao site (analytics)
model SiteVisit {
  id        Int      @id @default(autoincrement())
  page      String   @db.VarChar(100) // 'home', 'register', etc
  ip        String?  @db.VarChar(45)
  city      String?  @db.VarChar(100)
  region    String?  @db.VarChar(100)
  country   String?  @db.VarChar(10)
  userAgent String?  @map("user_agent") @db.VarChar(500)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("site_visits")
}

// Configurações do sistema (chave pix, instruções, etc)
model SystemConfig {
  id    Int    @id @default(autoincrement())
  key   String @unique @db.VarChar(100)
  value String @db.Text

  @@map("system_configs")
}
